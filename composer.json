{
    "name": "glueful/flags",
    "description": "Feature flags and rollout controls for Glueful apps.",
    "type": "glueful-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "Michael Tawiah Sowah",
            "email": "michael@glueful.dev"
        }
    ],
    "keywords": [
        "glueful",
        "feature-flags",
        "rollouts"
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "glueful/framework": "^1.54.0",
        "phpstan/phpstan": "^1.0",
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.6"
    },
    "homepage": "https://github.com/glueful/flags",
    "autoload": {
        "psr-4": {
            "Glueful\\Extensions\\Flags\\": "src/"
        },
        "classmap": [
            "migrations/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Glueful\\Extensions\\Flags\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyze": "vendor/bin/phpstan analyse",
        "phpcbf": "vendor/bin/phpcbf --standard=PSR12 src",
        "phpcs": "vendor/bin/phpcs --standard=PSR12 src",
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "glueful": {
            "name": "Flags",
            "displayName": "Flags",
            "description": "Feature flags and rollout controls for Glueful apps.",
            "version": "1.0.0",
            "categories": [
                "operations",
                "developer-tools"
            ],
            "publisher": "glueful-team",
            "provider": "Glueful\\Extensions\\Flags\\FlagsServiceProvider",
            "requires": {
                "glueful": ">=1.54.0",
                "extensions": []
            }
        }
    },
    "config": {
        "sort-packages": true
    }
}
